datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum EmployeeStatus {
  ACTIVE
  RESIGNED
  TERMINATED
  NOTICE_PERIOD
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum AdvanceDeductionStatus {
  PENDING
  DEDUCTED
}

enum DocumentType {
  PAN_CARD
  AADHAAR_CARD
  DRIVING_LICENSE
  BANK_PASSBOOK
  PHOTO
  OTHER
}

model Department {
  id   Int    @id @default(autoincrement())
  name String @unique

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Designation {
  id   Int    @id @default(autoincrement())
  name String @unique

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmploymentType {
  id   Int    @id @default(autoincrement())
  name String @unique

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id   Int    @id @default(autoincrement())
  name String @unique

  advances EmployeeAdvance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id Int @id @default(autoincrement())

  vehicleNumber String  @unique
  vehicleName   String?
  vehicleType   String?

  registrationNo  String?
  seatingCapacity Int?

  isActive Boolean @default(true)

  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id Int @id @default(autoincrement())

  employeeCode String? @unique

  firstName String
  lastName  String?

  phone String?
  email String?

  gender      String?
  dateOfBirth DateTime?

  joiningDate DateTime

  profilePhoto String?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  designationId Int?
  designation   Designation? @relation(fields: [designationId], references: [id])

  employmentTypeId Int?
  employmentType   EmploymentType? @relation(fields: [employmentTypeId], references: [id])

  panNumber        String?
  aadhaarNumber    String?
  drivingLicenseNo String?

  bankName          String?
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?

  joiningSalary Float?
  currentSalary Float?

  basicSalary Float?
  hra         Float?
  da          Float?

  pfEnabled     Boolean @default(false)
  pfPercentage  Float?  @default(12)
  pfSalaryLimit Float?  @default(15000)

  ptApplicable Boolean @default(true)
  ptAmount     Float?  @default(200)

  esicApplicable Boolean @default(false)

  status   EmployeeStatus @default(ACTIVE)
  isActive Boolean        @default(true)

  documents       EmployeeDocument[]
  attendances     Attendance[]
  salaryRevisions SalaryRevision[]
  advances        EmployeeAdvance[]
  payrolls        EmployeePayroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([departmentId])
  @@index([designationId])
  @@index([isActive])
}

model EmployeeDocument {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentType DocumentType

  documentName String?

  filePath String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

model Attendance {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  vehicleId Int?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  date DateTime

  status AttendanceStatus

  overtimeHours Float? @default(0)

  overtimeRemarks String?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@index([vehicleId, date])
  @@index([employeeId, status])
}

model SalaryRevision {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  previousSalary Float
  revisedSalary  Float

  basicSalary Float?
  hra         Float?
  da          Float?

  pfEnabled     Boolean @default(false)
  pfPercentage  Float?  @default(12)
  pfSalaryLimit Float?  @default(15000)

  ptApplicable Boolean @default(true)
  ptAmount     Float?  @default(200)

  esicApplicable Boolean @default(false)

  effectiveFrom DateTime

  revisionReason String?
  remarks        String?

  updatedById Int?

  updatedBy User? @relation("SalaryRevisionUpdatedBy", fields: [updatedById], references: [id])

  payrolls EmployeePayroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId, effectiveFrom])
}

model EmployeeAdvance {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  advanceDate DateTime @default(now())

  amount Float

  reason String?

  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  voucherNumber String?
  voucherPath   String?

  remarks String?

  deductionStatus AdvanceDeductionStatus @default(PENDING)

  deductionMonth Int?
  deductionYear  Int?

  deductedAt DateTime?

  givenById Int?

  givenBy User? @relation("AdvanceGivenBy", fields: [givenById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, deductionStatus])
  @@index([deductionStatus])
  @@index([deductionMonth, deductionYear])
}

model PayrollRun {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  month Int
  year  Int

  status PayrollRunStatus @default(DRAFT)

  processedAt DateTime?

  finalizedAt DateTime?

  finalizedById Int?

  finalizedBy User? @relation("PayrollRunFinalizedBy", fields: [finalizedById], references: [id])

  payrolls EmployeePayroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, month, year])
  @@index([companyId])
  @@index([status])
}

model EmployeePayroll {
  id Int @id @default(autoincrement())

  payrollRunId Int
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  salaryRevisionId Int?
  salaryRevision   SalaryRevision? @relation(fields: [salaryRevisionId], references: [id])

  // Attendance Snapshot
  workingDays Int

  presentDays Float

  absentDays Float @default(0)

  leaveDays Float @default(0)

  holidayDays Float @default(0)

  overtimeHours Float @default(0)

  // Salary Snapshot
  basicSalary Float

  hra Float

  da Float

  grossSalary Float

  // Deductions
  pfAmount Float @default(0)

  ptAmount Float @default(0)

  esicAmount Float @default(0)

  advanceDeduction Float @default(0)

  totalDeductions Float

  // Final Salary
  totalEarnings Float

  netSalary Float

  // Payslip
  salarySlipPath String?

  paidDate DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@index([payrollRunId])
}

model Company {
  id Int @id @default(autoincrement())

  companyName String
  ownerName   String

  phone String?
  email String?

  address String?

  gstNumber String?
  panNumber String?

  logo String?

  // Bank Details
  bankName          String?
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?

  employees   Employee[]
  payrollRuns PayrollRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  salaryRevisionsUpdated SalaryRevision[] @relation("SalaryRevisionUpdatedBy")

  advancesGiven EmployeeAdvance[] @relation("AdvanceGivenBy")

  payrollRunsFinalized PayrollRun[] @relation("PayrollRunFinalizedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique // Format suggestion: "user:create", "post:delete"
  roles RolePermission[]
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}
